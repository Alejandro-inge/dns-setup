$TTL 1D
@ IN SOA ubuntu-dhcp.local.lan. hostmaster.local.lan. (
        2026020300 ; serial

        8H ; refresh
        4H ; retry
        4W ; expire
        1D ) ; minimum
        IN A 10.0.4.2
        ;
@ IN NS ubuntu-dhcp.local.lan.
mysql        IN A 10.0.4.4
apache        IN A 10.0.4.5
samba        IN A 10.0.4.6